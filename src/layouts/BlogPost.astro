---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { AUTHOR, SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { readingMinutes?: number };

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	category,
	tags,
	readingMinutes,
} = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead
			title={`${title} — ${SITE_TITLE}`}
			description={description}
			image={heroImage}
		/>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<header class="post-header">
					<div class="reading-container">
						<a href={`/categories/${category.toLowerCase()}/`} class="category ui-text">{category}</a>
						<h1 class="title">{title}</h1>
						<p class="description">{description}</p>
						<div class="byline ui-text">
							<span class="author">{AUTHOR}</span>
							<span class="dot">·</span>
							<FormattedDate date={pubDate} />
							{readingMinutes && (
								<>
									<span class="dot">·</span>
									<span>{readingMinutes} min read</span>
								</>
							)}
						</div>
					</div>
				</header>

				{heroImage && (
					<div class="hero">
						<div class="container">
							<Image src={heroImage} alt="" width={1200} height={600} loading="eager" />
						</div>
					</div>
				)}

				<div class="prose reading-container">
					<slot />

					{updatedDate && (
						<p class="updated ui-text">
							Updated <FormattedDate date={updatedDate} />
						</p>
					)}

					{tags && tags.length > 0 && (
						<div class="tags ui-text">
							{tags.map((tag) => (
								<a href={`/tags/${tag.toLowerCase()}/`} class="tag">#{tag}</a>
							))}
						</div>
					)}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.post-header {
		padding: var(--space-xl) 0 var(--space-lg) 0;
		text-align: center;
	}
	.category {
		display: inline-block;
		font-size: 0.8125rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--color-accent);
		text-decoration: none;
		margin-bottom: 1rem;
		font-weight: 600;
	}
	.category:hover {
		color: var(--color-accent-hover);
		text-decoration: underline;
	}
	.title {
		font-size: 3rem;
		line-height: 1.1;
		margin: 0 0 1rem 0;
		letter-spacing: -0.025em;
	}
	.description {
		font-family: var(--font-serif-stack);
		font-style: italic;
		font-size: 1.25rem;
		color: var(--color-text-muted);
		margin: 0 0 1.5rem 0;
		line-height: 1.45;
	}
	.byline {
		font-size: 0.9375rem;
		color: var(--color-text-faint);
	}
	.author {
		color: var(--color-text-muted);
		font-weight: 500;
	}
	.dot {
		margin: 0 0.5rem;
	}
	.hero {
		margin: 0 0 var(--space-lg) 0;
	}
	.hero img {
		width: 100%;
		height: auto;
		border-radius: 4px;
	}
	.prose {
		font-size: 1.1875rem;
		line-height: 1.7;
		color: var(--color-text);
	}
	.prose :global(h2) {
		font-size: 1.75rem;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
	}
	.prose :global(h3) {
		font-size: 1.375rem;
		margin-top: 2rem;
		margin-bottom: 0.75rem;
	}
	.prose :global(p) {
		margin: 0 0 1.5em 0;
	}
	.prose :global(a) {
		color: var(--color-text);
		text-decoration: underline;
		text-decoration-color: var(--color-accent);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
	}
	.prose :global(a:hover) {
		color: var(--color-accent);
	}
	.prose :global(img) {
		margin: 2rem auto;
		border-radius: 4px;
	}
	.updated {
		font-size: 0.875rem;
		color: var(--color-text-faint);
		font-style: italic;
		margin-top: var(--space-lg);
	}
	.tags {
		margin-top: var(--space-lg);
		padding-top: var(--space-md);
		border-top: 1px solid var(--color-border);
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.tag {
		font-size: 0.8125rem;
		color: var(--color-text-muted);
		text-decoration: none;
		padding: 0.25rem 0.625rem;
		background: var(--color-border);
		border-radius: 3px;
	}
	.tag:hover {
		background: var(--color-accent);
		color: var(--color-bg);
	}
	@media (max-width: 720px) {
		.title {
			font-size: 2rem;
		}
		.description {
			font-size: 1.0625rem;
		}
		.post-header {
			padding: var(--space-lg) 0 var(--space-md) 0;
		}
	}
</style>
