---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { CATEGORIES } from '../../consts';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog', ({ data }) => !data.draft);
	return CATEGORIES.map((category) => {
		const posts = allPosts
			.filter((p) => p.data.category === category)
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
		return {
			params: { category: category.toLowerCase() },
			props: { category, posts },
		};
	});
}

const { category, posts } = Astro.props;
---

<BaseLayout
	title={category}
	description={`Posts in the ${category} category.`}
>
	<div class="container archive">
		<p class="eyebrow ui-text">Category</p>
		<h1 class="page-title">{category}</h1>
		<p class="count ui-text">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>

		{posts.length > 0 ? (
			<div class="post-list">
				{posts.map((post) => <PostCard post={post} />)}
			</div>
		) : (
			<p class="empty">No posts in this category yet.</p>
		)}
	</div>
</BaseLayout>

<style>
	.archive {
		padding: var(--space-lg) var(--space-md);
		max-width: 760px;
	}
	.eyebrow {
		font-size: 0.8125rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--color-accent);
		font-weight: 600;
		margin: 0 0 0.5rem 0;
	}
	.page-title {
		font-size: 2.5rem;
		margin: 0 0 0.5rem 0;
		letter-spacing: -0.02em;
	}
	.count {
		font-size: 0.875rem;
		color: var(--color-text-faint);
		margin: 0 0 var(--space-lg) 0;
	}
	.empty {
		color: var(--color-text-muted);
		font-style: italic;
		padding: var(--space-lg) 0;
	}
</style>
