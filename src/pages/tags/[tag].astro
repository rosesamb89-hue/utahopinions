---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog', ({ data }) => !data.draft);
	const tagMap = new Map<string, typeof allPosts>();

	for (const post of allPosts) {
		for (const tag of post.data.tags ?? []) {
			const key = tag.toLowerCase();
			if (!tagMap.has(key)) tagMap.set(key, []);
			tagMap.get(key)!.push(post);
		}
	}

	return Array.from(tagMap.entries()).map(([tag, posts]) => ({
		params: { tag },
		props: {
			tag,
			displayTag: posts[0].data.tags?.find((t) => t.toLowerCase() === tag) ?? tag,
			posts: posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

const { displayTag, posts } = Astro.props;
---

<BaseLayout
	title={`#${displayTag}`}
	description={`Posts tagged ${displayTag}.`}
>
	<div class="container archive">
		<p class="eyebrow ui-text">Tag</p>
		<h1 class="page-title">#{displayTag}</h1>
		<p class="count ui-text">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
		<div class="post-list">
			{posts.map((post) => <PostCard post={post} />)}
		</div>
	</div>
</BaseLayout>

<style>
	.archive {
		padding: var(--space-lg) var(--space-md);
		max-width: 760px;
	}
	.eyebrow {
		font-size: 0.8125rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--color-accent);
		font-weight: 600;
		margin: 0 0 0.5rem 0;
	}
	.page-title {
		font-size: 2.5rem;
		margin: 0 0 0.5rem 0;
	}
	.count {
		font-size: 0.875rem;
		color: var(--color-text-faint);
		margin: 0 0 var(--space-lg) 0;
	}
</style>
